#!name=369出行去广告
#!desc=去除开屏广告、首页无用选项
#!category=AdBlock
#!system=ios

[Body Rewrite]
# 去除开屏广告
http-response-jq ^https:\/\/api\.369cx\.cn\/v2\/Splash\/GetSplashAd '.result.picUrl = ""'
# 首页精简&优化功能顺序
http-response-jq ^https:\/\/api\.369cx\.cn\/v2\/Home\/GetHomePageData '.result |= ((.banner,.sales) = [] | .homeButton |= sort_by({"出行公告":0,"掌上大厅":1,"定制公交":2,"公交优选":3,"畅游卡":4,"公交+":5,"公交官网":6,"读城专栏":7,"单次票":8,"出行":9}[.name]// 114514))'

[MITM]
hostname = %APPEND% api.369cx.cn